# Idioma de Data Dragon (es_ES, es_MX, en_US, ...)
LOL_LANG=es_ES

# Carpeta de cache en disco
LOL_CACHE_DIR=.lol_cache

# Timeout de red en segundos
LOL_HTTP_TIMEOUT=20

# TTLs de cache (segundos)
LOL_WIKI_CACHE_TTL=86400
LOL_OPGG_CACHE_TTL=21600

# Cada cuánto revisa la app si hay parche nuevo (milisegundos)
LOL_PATCH_CHECK_INTERVAL_MS=1800000

# Refresco proactivo en segundo plano mientras la app corre (segundos, 0 = off)
LOL_REFRESH_INTERVAL_S=3600

# true para activar el modo debug de Dash
LOL_DEBUG=false

# Asistente IA local (requiere Ollama corriendo: https://ollama.com)
LOL_OLLAMA_HOST=http://127.0.0.1:11434
LOL_OLLAMA_MODEL=qwen3:8b

# Riot API para winrates de items/runas (gratuita en developer.riotgames.com;
# la key de desarrollo expira cada 24 h, la Personal API Key no)
RIOT_API_KEY=
LOL_RIOT_PLATFORM=la1
LOL_RIOT_REGION=americas

# URL del agregado de winrates publicado por GitHub Actions (vacío = no sincronizar)
LOL_WINRATES_SYNC_URL=https://raw.githubusercontent.com/AndresNungo2007/lol-consultor/winrates-data/winrates.json
